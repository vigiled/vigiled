  server.send_P(200, "text/html", OTA_HTML);
}

void handleUpdateUpload() {
  HTTPUpload& upload = server.upload();

  if (upload.status == UPLOAD_FILE_START) {
    Serial.printf("OTA: début upload %s\n", upload.filename.c_str());
    // Flash LEDs orange pour signaler le début
    for (int i = 0; i < NUM_LEDS; i++) strip.setPixelColor(i, strip.Color(255, 80, 0));
    strip.show();
    if (!Update.begin(UPDATE_SIZE_UNKNOWN)) {
      Update.printError(Serial);
    }
  } else if (upload.status == UPLOAD_FILE_WRITE) {
    if (Update.write(upload.buf, upload.currentSize) != upload.currentSize) {
      Update.printError(Serial);
    }
  } else if (upload.status == UPLOAD_FILE_END) {
    if (Update.end(true)) {
      Serial.printf("OTA: succès — %u bytes\n", upload.totalSize);
      // Flash vert succès
      for (int i = 0; i < NUM_LEDS; i++) strip.setPixelColor(i, strip.Color(0, 255, 80));
      strip.show();
    } else {
      Update.printError(Serial);
      for (int i = 0; i < NUM_LEDS; i++) strip.setPixelColor(i, strip.Color(255, 0, 0));
      strip.show();
    }
  }
}

