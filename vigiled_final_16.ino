  float t = (millis()-t0)/1000.0f;
  for (int i = 0; i < LEDS_ACTIVE; i++) {
    float bri = sinf(((float)i/(LEDS_ACTIVE-1))*TWO_PI - t*0.8f)*0.4f+0.6f;
    strip.setPixelColor(i, strip.Color(
      (uint8_t)(20*bri*brightness/255),
      (uint8_t)(80*bri*brightness/255),
      (uint8_t)(160*bri*brightness/255)));
  }
  strip.show(); delay(20);
}

// Mode 10 : SOS (morse S-O-S en blanc — mode caché, appui long BTN MODE)
// Réinitialise son état à chaque activation grâce au flag sosReset
bool sosReset = false;
void sosMode() {
  // S=...  O=---  S=...
  // Structure : durée allumé, durée éteint (par paire)
  static const uint16_t seq[] = {
    200,200, 200,200, 200,600,   // S : . . .
    600,200, 600,200, 600,600,   // O : - - -
    200,200, 200,200, 200,1400   // S : . . .
  };
  static uint8_t       idx  = 0;
  static bool          on   = false;
  static unsigned long last = 0;

  // Reset de l état à chaque nouvelle entrée en mode SOS
  if (!sosReset) {
    idx  = 0;
    on   = false;
    last = millis();
    sosReset = true;
    strip.clear(); strip.show();
    return;
  }

  unsigned long now = millis();
  if (now - last < seq[idx]) return;
  last = now;
  on = !on;
  strip.fill(on ? strip.Color(brightness, brightness, brightness) : 0, 0, LEDS_ACTIVE);
  strip.show();
  idx = (idx + 1) % (sizeof(seq) / sizeof(seq[0]));
}

// Mode 17 : Respiration biphasée (deux couleurs alternées en fondu)
void respirationBiphasee() {
  static unsigned long start = millis();
  unsigned long t = millis() - start;
  // Cycle complet : 8s (4s phase A → 4s phase B)
  uint32_t cycle = t % 8000;
  float bri = 0.0f;
  bool phaseA = (cycle < 4000);
  uint32_t local = phaseA ? cycle : cycle - 4000;
  // Fondu : 0→255 en 1.5s, plateau 1s, 255→0 en 1.5s
  if      (local < 1500) bri = (float)local / 1500.0f;
  else if (local < 2500) bri = 1.0f;
  else if (local < 4000) bri = 1.0f - (float)(local - 2500) / 1500.0f;
  uint8_t v = (uint8_t)(bri * brightness);
  // Phase A : bleu (couleur 1) — Phase B : violet (couleur 2)
  uint8_t r = phaseA ? 0   : (uint8_t)(v * 0.6f);
  uint8_t g = phaseA ? 0   : 0;
  uint8_t b = phaseA ? v   : v;
  strip.fill(strip.Color(r, g, b), 0, LEDS_ACTIVE);
  strip.show();
}

void veilleDiscrete() {
  static unsigned long t0=millis();
  float t=(float)((millis()-t0)%4000)/4000.0f;
  float sc=((sinf(t*TWO_PI-HALF_PI)+1.0f)/2.0f)*0.35f+0.02f;
  strip.clear();
  int mid=LEDS_ACTIVE/2;
  uint8_t r=(uint8_t)(40*sc*brightness/255),g=(uint8_t)(130*sc*brightness/255),b=(uint8_t)(80*sc*brightness/255);
  strip.setPixelColor(mid,strip.Color(r,g,b));
  if (mid>0)             strip.setPixelColor(mid-1,strip.Color(r/4,g/4,b/4));
  if (mid<LEDS_ACTIVE-1) strip.setPixelColor(mid+1,strip.Color(r/4,g/4,b/4));
  strip.show(); delay(20);
}

